<Window x:Class="MicShift.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicShift" 
        Height="510" Width="520"
        Background="#18181B"
        Foreground="#F4F4F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="logo.png">
    
    <Window.Resources>
        <!-- Pulsing Status Indicator Storyboard -->
        <Storyboard x:Key="PulseStoryboard">
            <DoubleAnimation Storyboard.TargetName="StatusIndicator" 
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0" Duration="0:0:1.0"
                             AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>

        <!-- iOS/Win11 Style Toggle Switch -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid x:Name="Grid" Width="44" Height="22" Cursor="Hand">
                                <Border x:Name="BackgroundBorder" Background="#3F3F46" CornerRadius="11" BorderThickness="0"/>
                                <Border x:Name="Thumb" Background="#F4F4F5" Width="18" Height="18" CornerRadius="9" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#06B6D4"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#27272A"/>
                                <Setter TargetName="Thumb" Property="Background" Value="#71717A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Modern Progress Bar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Flat Button -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3F3F46"/>
                                <Setter Property="BorderBrush" Value="#52525B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#71717A"/>
                                <Setter Property="Background" Value="#27272A"/>
                                <Setter Property="BorderBrush" Value="#27272A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Flat Danger Button -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Dark ComboBox Styling with Flat Popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Background="{TemplateBinding Background}" 
                                          Foreground="{TemplateBinding Foreground}"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="#A1A1AA" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#52525B"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#18181B"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#06B6D4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#18181B" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBoxItem Styling -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" SnapsToDevicePixels="true" CornerRadius="4" Padding="{TemplateBinding Padding}" Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="Border" Property="TextElement.Foreground" Value="#06B6D4"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="Border" Property="TextElement.Foreground" Value="#06B6D4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                                <Setter TargetName="Border" Property="TextElement.Foreground" Value="#06B6D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content Card -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="10" CornerRadius="8" Background="#27272A" BorderBrush="#3F3F46" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusIndicator" Grid.Column="0" Width="12" Height="12" Fill="#EF4444" VerticalAlignment="Center" Margin="5,0,10,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="MicShift Controller" FontWeight="Bold" FontSize="15" Foreground="#F4F4F5"/>
                    <TextBlock x:Name="StatusText" Text="Auto-Switching is Inactive" FontSize="11" Foreground="#A1A1AA"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Card -->
        <Border Grid.Row="1" Padding="15" CornerRadius="8" Background="#27272A" BorderBrush="#3F3F46" BorderThickness="1">
            <StackPanel>
                <!-- Dropdowns -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Desk Microphone" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" Margin="0,0,0,5"/>
                        <ComboBox x:Name="DeskMicComboBox" Height="30" SelectionChanged="OnMicSelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Headset Microphone" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" Margin="0,0,0,5"/>
                        <ComboBox x:Name="HeadsetMicComboBox" Height="30" SelectionChanged="OnMicSelectionChanged"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#3F3F46" Margin="0,0,0,15"/>

                <!-- Levels -->
                <TextBlock Text="Real-time Volume Levels" FontSize="11" FontWeight="SemiBold" Foreground="#A1A1AA" Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Desk Mic" FontSize="12" VerticalAlignment="Center" Foreground="#F4F4F5"/>
                    <ProgressBar x:Name="DeskLevelBar" Grid.Column="1" Height="14" Minimum="0" Maximum="100" Value="0" Foreground="#06B6D4" Background="#18181B" BorderThickness="0"/>
                    <TextBlock x:Name="DeskLevelValue" Grid.Column="2" Text="0.0%" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#A1A1AA"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Headset Mic" FontSize="12" VerticalAlignment="Center" Foreground="#F4F4F5"/>
                    <ProgressBar x:Name="HeadsetLevelBar" Grid.Column="1" Height="14" Minimum="0" Maximum="100" Value="0" Foreground="#10B981" Background="#18181B" BorderThickness="0"/>
                    <TextBlock x:Name="HeadsetLevelValue" Grid.Column="2" Text="0.0%" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#A1A1AA"/>
                </Grid>

                <!-- Auto-switch Toggle -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Automatic Switching (Auto-Distance)" FontWeight="SemiBold" FontSize="13" Foreground="#F4F4F5"/>
                        <TextBlock Text="Switches to the closest mic based on speech levels" FontSize="11" Foreground="#71717A"/>
                    </StackPanel>
                    <CheckBox x:Name="AutoSwitchToggle" Grid.Column="1" VerticalAlignment="Center" Checked="OnAutoSwitchToggled" Unchecked="OnAutoSwitchToggled" IsChecked="False" Style="{StaticResource ToggleSwitchStyle}"/>
                </Grid>

                <Separator Background="#3F3F46" Margin="0,0,0,15"/>

                <!-- Notifications Toggle -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Show Notifications" FontWeight="SemiBold" FontSize="13" Foreground="#F4F4F5"/>
                        <TextBlock Text="Display Toast alerts on state change" FontSize="11" Foreground="#71717A"/>
                    </StackPanel>
                    <CheckBox x:Name="NotificationsToggle" Grid.Column="1" VerticalAlignment="Center" Checked="OnNotificationsToggled" Unchecked="OnNotificationsToggled" IsChecked="True" Style="{StaticResource ToggleSwitchStyle}"/>
                </Grid>
            </StackPanel>
        </Border>
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="VersionTextBlock" Grid.Column="0" Text="v0.3.0" FontSize="11" Foreground="#71717A" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Minimize to Tray" Width="120" Height="30" Click="OnMinimizeToTrayClick" Margin="0,0,10,0" Style="{StaticResource ModernButtonStyle}"/>
                <Button Content="Exit" Width="80" Height="30" Click="OnExitClick" Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
