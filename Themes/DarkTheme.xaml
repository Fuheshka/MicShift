<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore">
    
    <SolidColorBrush x:Key="Background" Color="#18181B"/>
    <SolidColorBrush x:Key="CardBackground" Color="#27272A"/>
    <SolidColorBrush x:Key="Foreground" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="MutedText" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="AccentColor" Color="#06B6D4"/>
    <SolidColorBrush x:Key="SecondaryAccentColor" Color="#10B981"/>
    
    <SolidColorBrush x:Key="InputBackground" Color="#18181B"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#27272A"/>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#3F3F46"/>
