<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore">
    
    <SolidColorBrush x:Key="Background" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Foreground" Color="#18181B"/>
    <SolidColorBrush x:Key="MutedText" Color="#71717A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E4E4E7"/>
    <SolidColorBrush x:Key="AccentColor" Color="#0891B2"/>
    <SolidColorBrush x:Key="SecondaryAccentColor" Color="#059669"/>
    
    <SolidColorBrush x:Key="InputBackground" Color="#F4F4F5"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#E4E4E7"/>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#D4D4D8"/>
    <SolidColorBrush x:Key="ButtonHoverBorder" Color="#A1A1AA"/>
    <SolidColorBrush x:Key="ButtonPressedBackground" Color="#E4E4E7"/>
</ResourceDictionary>
